# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dictophone?schema=public"

# NextAuth / Auth.js — сгенерируйте: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Публичный URL приложения (NextAuth, canonical и Open Graph)
NEXTAUTH_URL="http://localhost:3000"

# Опционально: явный URL сайта для SEO (если отличается от NEXTAUTH_URL)
